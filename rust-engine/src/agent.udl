namespace rust_engine {
    // Error types that can be caught as Exceptions in Kotlin
    [Error]
    enum EngineError {
        "ConfigError",
        "NetworkError",
        "BookingFailed",
        "InternalError"
    };

    // Dictionary representing the real-time state for the Android UI
    dictionary EngineStatus {
        boolean is_running;
        string last_log;
        string current_run_id;
    };

    // The core interface that Android will instantiate
    interface BookingAgent {
        // Creates a new instance of the agent
        constructor();

        // Starts a high-precision strike. 
        // config_json: Entire application state serialized to JSON
        // run_id: Unique UUID for this specific execution
        [ThreadSafe]
        async fn start_strike(config_json: string, run_id: string) -> Result<boolean, EngineError>;

        // Force stops any active operations and shuts down the tokio runtime
        [ThreadSafe]
        fn stop();

        // Polls the current status of the engine for UI updates
        [ThreadSafe]
        async fn get_status() -> EngineStatus;
    };
};
